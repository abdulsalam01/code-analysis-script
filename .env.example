# Weekly Commit Analysis Script configuration
# Copy this file's values to match the repository you want to analyze.

# Required when you do not pass a repo path/URL on the command line.
# Use "." to analyze this project itself for a quick smoke test.
ANALYZER_REPO=https://github.com/abdulsalam01/food-webapp

# Optional analysis settings.
ANALYZER_BRANCH=
ANALYZER_AUTHOR=
ANALYZER_DAYS=7
ANALYZER_WORKDIR=/tmp/weekly-commit-analysis
ANALYZER_OUTPUT=reports/weekly_commit_analysis.md
ANALYZER_JSON_OUTPUT=reports/weekly_commit_analysis.json
ANALYZER_PRINT_PROMPT=false

# Optional Gemini-assisted analysis. Leave disabled until you add a real key.
ANALYZER_USE_GEMINI=false
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=<key-here>
